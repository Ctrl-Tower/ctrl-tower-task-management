# Postgres connection string used by the app.
# Locally: your local Postgres. On Neon: the POOLED ("-pooler") connection string.
DATABASE_URL="postgresql://taskboard:taskboard@localhost:5433/taskboard?schema=public"
# Direct (unpooled) connection used only for migrations.
# Locally: same as DATABASE_URL. On Neon: provided automatically as DATABASE_URL_UNPOOLED.
DATABASE_URL_UNPOOLED="postgresql://taskboard:taskboard@localhost:5433/taskboard?schema=public"

# Secret used to sign session JWTs. Generate: openssl rand -base64 32
JWT_SECRET="change-me-to-a-long-random-string"

# Seed user credentials (used by prisma/seed.ts)
SEED_USER_NAME=""
SEED_USER_PASSWORD=""
